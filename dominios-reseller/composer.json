{
    "name": "replanta/dominios-reseller-tests",
    "description": "Dev tooling for Dominios Reseller (PHPUnit unit tests for Forest Program helpers).",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit --testdox"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}

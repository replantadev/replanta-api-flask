{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"customDuotone": false,
			"palette": [
				{ "slug": "bg",          "name": "Background",   "color": "#FBFAF6" },
				{ "slug": "fg",          "name": "Foreground",   "color": "#0E1A14" },
				{ "slug": "muted",       "name": "Muted",        "color": "#6B7568" },
				{ "slug": "surface",     "name": "Surface",      "color": "#F1EFE7" },
				{ "slug": "border",      "name": "Border",       "color": "#D9D6CA" },
				{ "slug": "primary",     "name": "Primary",      "color": "#1F6F45" },
				{ "slug": "primary-fg",  "name": "Primary FG",   "color": "#FFFFFF" },
				{ "slug": "accent",      "name": "Accent",       "color": "#E8B84C" },
				{ "slug": "accent-fg",   "name": "Accent FG",    "color": "#0E1A14" },
				{ "slug": "success",     "name": "Success",      "color": "#2E8F5E" },
				{ "slug": "danger",      "name": "Danger",       "color": "#B23A3A" }
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "serif",
					"name": "Serif",
					"fontFamily": "\"DM Serif Display\", ui-serif, Georgia, serif",
					"fontFace": [
						{
							"fontFamily": "DM Serif Display",
							"fontWeight": "400",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/dm-serif-display-400.woff2"],
							"fontDisplay": "swap"
						}
					]
				},
				{
					"slug": "sans",
					"name": "Sans",
					"fontFamily": "\"DM Sans\", ui-sans-serif, system-ui, sans-serif",
					"fontFace": [
						{
							"fontFamily": "DM Sans",
							"fontWeight": "400 700",
							"fontStyle": "normal",
							"src": ["file:./assets/fonts/dm-sans-var.woff2"],
							"fontDisplay": "swap"
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "sm",  "size": "0.875rem",                               "name": "Small" },
				{ "slug": "md",  "size": "1rem",                                   "name": "Medium" },
				{ "slug": "lg",  "size": "1.125rem",                               "name": "Large" },
				{ "slug": "xl",  "size": "clamp(1.25rem, 1rem + 1vw, 1.5rem)",     "name": "XL" },
				{ "slug": "2xl", "size": "clamp(1.5rem, 1.1rem + 2vw, 2rem)",      "name": "2XL" },
				{ "slug": "3xl", "size": "clamp(2rem, 1.2rem + 3vw, 3rem)",        "name": "3XL" },
				{ "slug": "4xl", "size": "clamp(2.5rem, 1.5rem + 4vw, 4.5rem)",    "name": "4XL" }
			]
		},
		"spacing": {
			"units": ["px", "rem", "em", "%", "vh", "vw"],
			"spacingScale": { "operator": "*", "increment": 1.5, "steps": 8, "mediumStep": 1.5, "unit": "rem" }
		},
		"border": {
			"color": true,
			"radius": true,
			"style": true,
			"width": true
		},
		"custom": {
			"radius": {
				"sm": "0.375rem",
				"md": "0.625rem",
				"lg": "1rem",
				"xl": "1.5rem",
				"pill": "9999px"
			},
			"shadow": {
				"sm": "0 1px 2px rgba(14,26,20,0.06)",
				"md": "0 4px 16px rgba(14,26,20,0.08)",
				"lg": "0 12px 40px rgba(14,26,20,0.12)"
			},
			"transition": {
				"fast": "120ms cubic-bezier(.2,.8,.2,1)",
				"base": "200ms cubic-bezier(.2,.8,.2,1)"
			}
		}
	},
	"styles": {
		"color": { "background": "var(--wp--preset--color--bg)", "text": "var(--wp--preset--color--fg)" },
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "var(--wp--preset--font-size--md)",
			"lineHeight": "1.6"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--serif)",
					"lineHeight": "1.15",
					"fontWeight": "400",
					"letterSpacing": "-0.01em"
				}
			},
			"h1": { "typography": { "fontSize": "var(--wp--preset--font-size--4xl)" } },
			"h2": { "typography": { "fontSize": "var(--wp--preset--font-size--3xl)" } },
			"h3": { "typography": { "fontSize": "var(--wp--preset--font-size--2xl)" } },
			"link": {
				"color": { "text": "var(--wp--preset--color--primary)" },
				":hover": { "typography": { "textDecoration": "underline" } }
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--primary-fg)"
				},
				"border": { "radius": "var(--wp--custom--radius--md)" },
				"spacing": { "padding": { "top": "0.75rem", "right": "1.25rem", "bottom": "0.75rem", "left": "1.25rem" } },
				":hover": { "color": { "background": "var(--wp--preset--color--fg)" } }
			}
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--40, 1.5rem)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--40, 1.5rem)"
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-wide",   "title": "Page (wide)",   "postTypes": ["page", "rt_page"] },
		{ "name": "page-narrow", "title": "Page (narrow)", "postTypes": ["page", "rt_page"] }
	]
}
